<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Admin dashboard for member registration management.">
  <title>Admin Dashboard | Royal Rangers</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container navbar">
      <a class="brand" href="/">
        <img src="/images/logo.svg" alt="Royal Rangers Nigeria Southwest Zone 2">
        <span>Admin Portal</span>
      </a>
      <nav class="nav-links">
        <a href="/">Public Site</a>
        <a href="/admin/logout">Logout</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <section class="section">
      <div class="section-title">
        <span class="badge">Admin Dashboard</span>
        <h2>Member Database Control</h2>
        <p>Welcome, <%= adminEmail %>. View, approve, update, or export member records from the portal.</p>
      </div>
      <div class="card">
        <div style="display:flex; gap:1rem; flex-wrap:wrap; align-items:center; justify-content:space-between;">
          <p>Member database is organized by rank, district, unit, and status.</p>
          <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
            <button class="button" id="refresh-members">Refresh List</button>
            <button class="button" id="approve-all-btn" style="background:#4caf50;">Approve All Pending</button>
          </div>
        </div>
      </div>
      <div id="members-container" class="section-grid-1" style="display:grid; gap:1rem; margin-top:1.5rem;"></div>
    </section>

    <section class="section alt">
      <div class="section-title">
        <h2>Feedback & Complaints</h2>
        <p>View and respond to feedback submissions from applicants and public.</p>
      </div>
      <div style="display:flex; gap:0.75rem; margin-bottom:1.5rem;">
        <button class="button" id="refresh-feedback">Refresh Feedback</button>
      </div>
      <div id="feedback-container" class="section-grid-1" style="display:grid; gap:1rem;"></div>
    </section>
  </main>
  <script src="/js/admin.js"></script>
</body>
</html>
