<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Admin login for Royal Rangers Nigeria Southwest Zone 2 portal.">
  <title>Admin Login | Royal Rangers</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
  <main class="login-container">
    <div class="login-card">
      <div class="login-header">
        <img src="/images/logo.png" alt="Royal Rangers Nigeria Southwest Zone 2" class="login-logo">
        <span class="badge">Admin Portal</span>
        <h2>Welcome Back</h2>
        <p>Sign in to manage the member database and portal tools.</p>
      </div>
      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>
      <form action="/admin/login" method="post" class="login-form">
        <div class="field">
          <label for="email">Email</label>
          <div class="input-wrap">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
            <input id="email" name="email" type="email" placeholder="admin@royalrangerssw2.ng" required>
          </div>
        </div>
        <div class="field">
          <label for="password">Password</label>
          <div class="input-wrap">
            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <input id="password" name="password" type="password" placeholder="Enter your password" required>
          </div>
        </div>
        <button type="submit" class="button login-btn">Sign In</button>
        <a href="/forgot-password" class="login-forgot">Forgot Password?</a>
      </form>
    </div>
  </main>
</body>
</html>
