<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Reset password - Royal Rangers Nigeria Southwest Zone 2.">
  <title>Reset Password | Royal Rangers</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <main class="container" style="padding: 5rem 0;">
    <section class="section">
      <div class="section-title">
        <span class="badge">Password Reset</span>
        <h2>Reset Your Password</h2>
        <p>Enter your new password below.</p>
      </div>
      <div class="contact-card">
        <% if (error) { %>
          <p style="color:#ff8a65; font-weight:700;"><%= error %></p>
        <% } %>
        <% if (success) { %>
          <p style="color:#4caf50; font-weight:700;"><%= success %></p>
          <p style="text-align:center; margin-top:1rem;">
            <a href="/admin/login" class="button">Go to Admin Login</a>
            <br><br>
            <a href="/applicant-login.html">Go to Applicant Login</a>
          </p>
        <% } else if (token) { %>
          <form action="/reset-password/<%= token %>" method="post">
            <div class="form-grid">
              <div class="field">
                <label for="password">New Password</label>
                <input id="password" name="password" type="password" required minlength="6">
              </div>
              <div class="field">
                <label for="confirmPassword">Confirm New Password</label>
                <input id="confirmPassword" name="confirmPassword" type="password" required minlength="6">
              </div>
            </div>
            <button type="submit" class="button">Reset Password</button>
          </form>
        <% } else { %>
          <p style="text-align:center;">
            <a href="/forgot-password">Request a new reset link</a>
          </p>
        <% } %>
      </div>
    </section>
  </main>
</body>
</html>
